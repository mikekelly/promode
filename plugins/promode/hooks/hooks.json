{
  "description": "promode: inject the main-agent orchestration brief at session start (main agent only), split into self-contained chunks to stay under the 10k hook-output cap",
  "hooks": {
    "SessionStart": [
      { "matcher": "startup", "hooks": [
        { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/promode-main-context.sh", "${CLAUDE_PLUGIN_ROOT}/PROMODE_MAIN_AGENT.md", "1"] },
        { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/promode-main-context.sh", "${CLAUDE_PLUGIN_ROOT}/PROMODE_MAIN_AGENT.md", "2"] },
        { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/promode-main-context.sh", "${CLAUDE_PLUGIN_ROOT}/PROMODE_MAIN_AGENT.md", "3"] }
      ] },
      { "matcher": "resume", "hooks": [
        { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/promode-main-context.sh", "${CLAUDE_PLUGIN_ROOT}/PROMODE_MAIN_AGENT.md", "1"] },
        { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/promode-main-context.sh", "${CLAUDE_PLUGIN_ROOT}/PROMODE_MAIN_AGENT.md", "2"] },
        { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/promode-main-context.sh", "${CLAUDE_PLUGIN_ROOT}/PROMODE_MAIN_AGENT.md", "3"] }
      ] },
      { "matcher": "clear", "hooks": [
        { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/promode-main-context.sh", "${CLAUDE_PLUGIN_ROOT}/PROMODE_MAIN_AGENT.md", "1"] },
        { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/promode-main-context.sh", "${CLAUDE_PLUGIN_ROOT}/PROMODE_MAIN_AGENT.md", "2"] },
        { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/promode-main-context.sh", "${CLAUDE_PLUGIN_ROOT}/PROMODE_MAIN_AGENT.md", "3"] }
      ] },
      { "matcher": "compact", "hooks": [
        { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/promode-main-context.sh", "${CLAUDE_PLUGIN_ROOT}/PROMODE_MAIN_AGENT.md", "1"] },
        { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/promode-main-context.sh", "${CLAUDE_PLUGIN_ROOT}/PROMODE_MAIN_AGENT.md", "2"] },
        { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/promode-main-context.sh", "${CLAUDE_PLUGIN_ROOT}/PROMODE_MAIN_AGENT.md", "3"] }
      ] }
    ]
  }
}
